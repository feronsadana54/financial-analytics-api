{
  "info": {
    "_postman_id": "0a1b2c3d-4e5f-4061-8723-9a0b1c2d3e4f",
    "name": "Financial Analytics API",
    "description": "Collection lengkap untuk Financial Analytics API. Endpoint dikelompokkan per resource: Auth, Dashboard, Users, Products, Categories, Sales, Expenses.\n\nSemua endpoint protected memakai header Authorization: Bearer {{accessToken}}. Jalankan request Login Admin terlebih dahulu agar token otomatis tersimpan ke environment variable accessToken.\n\nResponse backend memakai envelope { success, message, data }. Test script di collection ini membaca token dan ID dari response.data.\n\nGunakan environment Financial Analytics Local saat menjalankan request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "description": "Endpoint untuk login, register, dan mengambil profil user yang sedang login. Login akan otomatis menyimpan accessToken ke environment.",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 or 201\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (error) { body = {}; }",
                  "",
                  "var data = body && body.data ? body.data : {};",
                  "var token = data.accessToken || data.token || body.accessToken;",
                  "if (token) {",
                  "    pm.environment.set(\"accessToken\", token);",
                  "    console.log(\"accessToken stored to environment\");",
                  "} else {",
                  "    console.warn(\"Login response did not contain accessToken\");",
                  "}",
                  "",
                  "if (data && data.user && data.user.id) {",
                  "    pm.environment.set(\"currentUserId\", data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login sebagai SUPER_ADMIN. Token disimpan otomatis ke variable accessToken."
          }
        },
