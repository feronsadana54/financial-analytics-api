    {
      "name": "Users",
      "description": "User management. GET list dan detail untuk MANAGER+ . POST/PATCH/DELETE hanya untuk SUPER_ADMIN. Login sebagai admin terlebih dahulu. DELETE bersifat soft delete: status diubah menjadi INACTIVE.",
      "item": [
        {
          "name": "Get Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (error) { body = {}; }",
                  "const list = body && Array.isArray(body.data) ? body.data : [];",
                  "if (list.length > 0 && list[0] && list[0].id) {",
                  "    pm.environment.set(\"userId\", list[0].id);",
                  "    console.log(\"userId set to first user in list\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Get User Detail",
          "request": {
            "method": "GET",
            "header": [
